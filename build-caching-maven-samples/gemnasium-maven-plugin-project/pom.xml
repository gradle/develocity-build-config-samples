<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/maven-v4_0_0.xsd">
  <modelVersion>4.0.0</modelVersion>
  <artifactId>gemnasium-maven-plugin-project</artifactId>
  <packaging>jar</packaging>

  <parent>
    <groupId>com.example</groupId>
    <artifactId>develocity-maven-caching-sample</artifactId>
    <version>1.0-SNAPSHOT</version>
  </parent>

  <dependencies>
    <dependency>
      <groupId>org.apache.commons</groupId>
      <artifactId>commons-lang3</artifactId>
      <version>3.17.0</version>
    </dependency>
    <dependency>
      <groupId>com.google.code.gson</groupId>
      <artifactId>gson</artifactId>
      <version>2.11.0</version>
    </dependency>
  </dependencies>

  <build>
    <plugins>
      <plugin>
        <groupId>com.gemnasium</groupId>
        <artifactId>gemnasium-maven-plugin</artifactId>
        <version>0.7.0</version>
        <executions>
          <execution>
            <id>dump-dependencies</id>
            <phase>validate</phase>
            <goals>
              <goal>dump-dependencies</goal>
            </goals>
          </execution>
        </executions>
      </plugin>
    </plugins>
    <pluginManagement>
      <plugins>
        <plugin>
          <groupId>com.gradle</groupId>
          <artifactId>develocity-maven-extension</artifactId>
          <configuration>
            <develocity>
              <plugins>
                <plugin>
                  <groupId>com.gemnasium</groupId>
                  <artifactId>gemnasium-maven-plugin</artifactId>
                  <executions>
                    <execution>
                      <id>dump-dependencies</id>
                      <inputs>
                        <properties>
                          <property>
                            <name>ignoredScopes</name>
                          </property>
                        </properties>
                        <ignoredProperties>
                          <!-- baseDir only affects where the JSON is written, not its content -->
                          <ignore>baseDir</ignore>
                        </ignoredProperties>
                      </inputs>
                      <nestedProperties>
                        <property>
                          <name>project</name>
                          <iteratedProperties>
                            <!--
                              The mojo reads resolved artifacts (project.artifacts, TEST scope collection)
                              for the full dependency dump, and project.dependencies for the declared list.
                              Both end up in the JSON output, so both contribute to the cache key.
                            -->
                            <property>
                              <name>artifacts</name>
                              <inputs>
                                <properties>
                                  <property>
                                    <name>groupId</name>
                                  </property>
                                  <property>
                                    <name>artifactId</name>
                                  </property>
                                  <property>
                                    <name>version</name>
                                  </property>
                                  <property>
                                    <name>type</name>
                                  </property>
                                  <property>
                                    <name>classifier</name>
                                  </property>
                                  <property>
                                    <name>scope</name>
                                  </property>
                                </properties>
                              </inputs>
                            </property>
                            <property>
                              <name>dependencies</name>
                              <inputs>
                                <properties>
                                  <property>
                                    <name>groupId</name>
                                  </property>
                                  <property>
                                    <name>artifactId</name>
                                  </property>
                                  <property>
                                    <name>version</name>
                                  </property>
                                  <property>
                                    <name>type</name>
                                  </property>
                                  <property>
                                    <name>scope</name>
                                  </property>
                                </properties>
                              </inputs>
                            </property>
                          </iteratedProperties>
                        </property>
                      </nestedProperties>
                      <outputs>
                        <files>
                          <file>
                            <name>dependencyDump</name>
                            <path>${project.basedir}/gemnasium-maven-plugin.json</path>
                          </file>
                        </files>
                        <cacheableBecause>dependency dump only changes when resolved artifacts or ignoredScopes change</cacheableBecause>
                      </outputs>
                    </execution>
                  </executions>
                </plugin>
              </plugins>
            </develocity>
          </configuration>
        </plugin>
      </plugins>
    </pluginManagement>
  </build>

</project>
